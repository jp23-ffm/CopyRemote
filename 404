    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Outfit', sans-serif;
        background: var(--deep-navy);
        color: var(--white);
        overflow: hidden;
        position: relative;
    }

    /* Animated background mesh */
    body::before {
        content: '';
        position: fixed;
        inset: 0;
        background:
            radial-gradient(ellipse 600px 400px at 20% 30%, rgba(26, 111, 181, 0.15), transparent),
            radial-gradient(ellipse 500px 500px at 80% 70%, rgba(91, 45, 142, 0.12), transparent),
            radial-gradient(ellipse 300px 300px at 50% 50%, rgba(62, 198, 224, 0.06), transparent);
        animation: meshShift 12s ease-in-out infinite alternate;
        z-index: 0;
    }

    @keyframes meshShift {
        0% { filter: hue-rotate(0deg); transform: scale(1); }
        100% { filter: hue-rotate(15deg); transform: scale(1.1); }
    }

    /* Subtle grid overlay */
    body::after {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
            linear-gradient(rgba(200, 202, 216, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(200, 202, 216, 0.03) 1px, transparent 1px);
        background-size: 60px 60px;
        z-index: 0;
    }

    .container {
        position: relative;
        z-index: 1;
        text-align: center;
        padding: 2rem;
        max-width: 560px;
    }

    .logo-wrapper {
        margin-bottom: 2.5rem;
        animation: logoIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .logo-wrapper img {
        width: 100px;
        height: auto;
        filter: drop-shadow(0 0 30px rgba(62, 198, 224, 0.2));
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .logo-wrapper img:hover {
        transform: scale(1.08) rotate(-2deg);
    }

    @keyframes logoIn {
        from { opacity: 0; transform: translateY(-20px) scale(0.9); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .error-code {
        font-size: clamp(6rem, 15vw, 10rem);
        font-weight: 800;
        line-height: 1;
        letter-spacing: -0.04em;
        background: linear-gradient(135deg, var(--chimera-blue), var(--accent-cyan), var(--chimera-purple));
        background-size: 200% 200%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: codeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both,
                   gradientFlow 6s ease infinite;
        position: relative;
    }

    @keyframes codeIn {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes gradientFlow {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }

    .error-code::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 3px;
        background: linear-gradient(90deg, var(--chimera-blue), var(--chimera-purple));
        border-radius: 2px;
    }

    .message {
        margin-top: 1.8rem;
        font-size: 1.15rem;
        font-weight: 300;
        color: var(--pale-silver);
        line-height: 1.7;
        animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
    }

    .message strong {
        font-weight: 600;
        color: var(--white);
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .actions {
        margin-top: 2.5rem;
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.8rem 1.8rem;
        border-radius: 10px;
        font-family: 'Outfit', sans-serif;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        cursor: pointer;
        border: none;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--chimera-blue), var(--chimera-purple));
        color: var(--white);
        box-shadow: 0 4px 20px rgba(26, 111, 181, 0.3);
    }

    .btn-primary:hover {
        transform: translateY(-2px) scale(1.03);
        box-shadow: 0 8px 30px rgba(26, 111, 181, 0.45);
    }

    .btn-secondary {
        background: rgba(200, 202, 216, 0.08);
        color: var(--pale-silver);
        border: 1px solid rgba(200, 202, 216, 0.12);
        backdrop-filter: blur(10px);
    }

    .btn-secondary:hover {
        background: rgba(200, 202, 216, 0.14);
        color: var(--white);
        transform: translateY(-2px);
        border-color: rgba(200, 202, 216, 0.25);
    }

    .btn svg {
        width: 18px;
        height: 18px;
    }

    /* Floating particles */
    .particle {
        position: fixed;
        width: 3px;
        height: 3px;
        background: var(--accent-cyan);
        border-radius: 50%;
        opacity: 0;
        z-index: 0;
        animation: float linear infinite;
    }

    @keyframes float {
        0% { opacity: 0; transform: translateY(100vh) scale(0); }
        10% { opacity: 0.6; }
        90% { opacity: 0.4; }
        100% { opacity: 0; transform: translateY(-10vh) scale(1); }
    }

    @media (max-width: 480px) {
        .container { padding: 1.5rem; }
        .logo-wrapper img { width: 72px; }
        .message { font-size: 1rem; }
        .actions { flex-direction: column; }
        .btn { justify-content: center; }
    }
</style>
